<!-- Post-detection refinement uses a dedicated low-speed Omni controller and
     avoids large spin or backup recovery motions near the observed table. -->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="2" name="NavigateFineRecovery">
      <PipelineSequence>
        <RateController hz="2.0" name="RateControllerComputeFinePath">
          <RecoveryNode number_of_retries="1" name="RecoveryComputeFinePath">
            <Fallback name="FallbackComputeFinePath">
              <ReactiveSequence name="CheckIfNewFinePathNeeded">
                <Inverter>
                  <GlobalUpdatedGoal/>
                </Inverter>
                <IsPathValid path="{path}"/>
              </ReactiveSequence>
              <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            </Fallback>
            <ClearEntireCostmap name="ClearGlobalCostmap-Fine" service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="RecoveryFollowFinePath">
          <FollowPath path="{path}" controller_id="FinePath" goal_checker_id="FineGoalChecker"/>
          <ClearEntireCostmap name="ClearLocalCostmap-Fine" service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="FallbackFineRecoveries">
        <GoalUpdated/>
        <RoundRobin name="FineRecoveryActions">
          <Sequence name="FineClearingActions">
            <ClearEntireCostmap name="ClearLocalCostmap-FineSubtree" service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-FineSubtree" service_name="global_costmap/clear_entirely_global_costmap"/>
          </Sequence>
          <Wait name="WaitFineRecovery" wait_duration="1"/>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
