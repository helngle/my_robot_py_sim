<?xml version="1.0"?>
<robot name="mobile_manipulator">

  <!-- ===== MATERIALS ===== -->
  <material name="base_blue">
    <color rgba="0.12 0.18 0.24 1"/>
  </material>
  <material name="torso_blue">
    <color rgba="0.22 0.36 0.48 1"/>
  </material>
  <material name="arm_red">
    <color rgba="0.86 0.24 0.18 1"/>
  </material>
  <material name="forearm_orange">
    <color rgba="0.95 0.50 0.18 1"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.02 0.02 0.025 1"/>
  </material>
  <material name="sensor_black">
    <color rgba="0.05 0.05 0.06 1"/>
  </material>
  <material name="sensor_mount_gray">
    <color rgba="0.18 0.20 0.22 1"/>
  </material>
  <material name="lidar_blue">
    <color rgba="0.10 0.45 0.75 1"/>
  </material>

  <!-- ===== BASE LINKS ===== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.185"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="18.0"/>
      <inertia ixx="0.60" ixy="0" ixz="0" iyy="0.90" iyz="0" izz="1.05"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.72 0.56 0.24"/>
      </geometry>
      <material name="base_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.72 0.56 0.24"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== WHEEL LINKS ===== -->
  <link name="front_left_wheel_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
    </collision>
  </link>

  <link name="front_right_wheel_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
    </collision>
  </link>

  <link name="rear_left_wheel_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
    </collision>
  </link>

  <link name="rear_right_wheel_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.105" length="0.11"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== TORSO ===== -->
  <link name="torso_link">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.42" ixy="0" ixz="0" iyy="0.36" iyz="0" izz="0.22"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.44 0.36 0.68"/>
      </geometry>
      <material name="torso_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.44 0.36 0.68"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== HEAD ===== -->
  <link name="head_sensor_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.26 0.24 0.18"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.26 0.24 0.18"/>
      </geometry>
    </collision>
  </link>

  <link name="sensor_mount_link">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.16 0.12 0.08"/>
      </geometry>
      <material name="sensor_mount_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.16 0.12 0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="lidar_link">
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0015" iyz="0" izz="0.0015"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.07" length="0.08"/>
      </geometry>
      <material name="lidar_blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.07" length="0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== LEFT ARM LINKS ===== -->
  <link name="left_upper_arm_link">
    <inertial>
      <mass value="1.4"/>
      <inertia ixx="0.035" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.035"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.17"/>
      <geometry>
        <cylinder radius="0.045" length="0.34"/>
      </geometry>
      <material name="arm_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.17"/>
      <geometry>
        <cylinder radius="0.045" length="0.34"/>
      </geometry>
    </collision>
  </link>

  <link name="left_forearm_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.025"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.15"/>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
      <material name="forearm_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.15"/>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
    </collision>
  </link>

  <link name="left_hand_link">
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.10 0.07 0.12"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.10 0.07 0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== RIGHT ARM LINKS ===== -->
  <link name="right_upper_arm_link">
    <inertial>
      <mass value="1.4"/>
      <inertia ixx="0.035" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.035"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.17"/>
      <geometry>
        <cylinder radius="0.045" length="0.34"/>
      </geometry>
      <material name="arm_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.17"/>
      <geometry>
        <cylinder radius="0.045" length="0.34"/>
      </geometry>
    </collision>
  </link>

  <link name="right_forearm_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.025"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.15"/>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
      <material name="forearm_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.15"/>
      <geometry>
        <cylinder radius="0.04" length="0.30"/>
      </geometry>
    </collision>
  </link>

  <link name="right_hand_link">
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.10 0.07 0.12"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.10 0.07 0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== WHEEL JOINTS ===== -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="0.24 0.34 -0.08"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="0.24 -0.34 -0.08"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel_link"/>
    <origin xyz="-0.24 0.34 -0.08"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel_link"/>
    <origin xyz="-0.24 -0.34 -0.08"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===== TORSO & HEAD JOINTS ===== -->
  <joint name="torso_fixed_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso_link"/>
    <origin xyz="0 0 0.46"/>
  </joint>

  <joint name="head_fixed_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="head_sensor_link"/>
    <origin xyz="0.04 0 0.43"/>
  </joint>

  <joint name="sensor_mount_fixed_joint" type="fixed">
    <parent link="head_sensor_link"/>
    <child link="sensor_mount_link"/>
    <origin xyz="0.16 0 0.10"/>
  </joint>

  <joint name="lidar_fixed_joint" type="fixed">
    <parent link="sensor_mount_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.02 0 0.08"/>
  </joint>

  <!-- ===== LEFT ARM JOINTS ===== -->
  <joint name="left_shoulder_yaw_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="left_upper_arm_link"/>
    <origin xyz="0 0.22 0.25" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.745" upper="1.745" effort="80" velocity="1.5"/>
  </joint>

  <joint name="left_elbow_joint" type="fixed">
    <parent link="left_upper_arm_link"/>
    <child link="left_forearm_link"/>
    <origin xyz="0 0 -0.34"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.356" upper="0.175" effort="60" velocity="1.5"/>
  </joint>

  <joint name="left_hand_fixed_joint" type="fixed">
    <parent link="left_forearm_link"/>
    <child link="left_hand_link"/>
    <origin xyz="0 0 -0.32"/>
  </joint>

  <!-- ===== RIGHT ARM JOINTS ===== -->
  <joint name="right_shoulder_yaw_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="right_upper_arm_link"/>
    <origin xyz="0 -0.22 0.25" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.745" upper="1.745" effort="80" velocity="1.5"/>
  </joint>

  <joint name="right_elbow_joint" type="fixed">
    <parent link="right_upper_arm_link"/>
    <child link="right_forearm_link"/>
    <origin xyz="0 0 -0.34"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.175" upper="2.356" effort="60" velocity="1.5"/>
  </joint>

  <joint name="right_hand_fixed_joint" type="fixed">
    <parent link="right_forearm_link"/>
    <child link="right_hand_link"/>
    <origin xyz="0 0 -0.32"/>
  </joint>

  <!-- ===== GAZEBO APPEARANCE AND CONTROL ===== -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="torso_link">
    <material>Gazebo/SteelBlue</material>
  </gazebo>
  <gazebo reference="head_sensor_link">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="sensor_mount_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Blue</material>
    <sensor name="head_gpu_lidar" type="gpu_lidar">
      <topic>/lidar/points</topic>
      <update_rate>8</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.35</min_angle>
            <max_angle>0.35</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.02</resolution>
        </range>
      </lidar>
      <alwaysOn>1</alwaysOn>
      <visualize>true</visualize>
    </sensor>
  </gazebo>
  <gazebo reference="front_left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="front_right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="rear_left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="rear_right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher"/>

    <plugin filename="ignition-gazebo-pose-publisher-system" name="ignition::gazebo::systems::PosePublisher">
      <publish_model_pose>true</publish_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
    </plugin>

    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.68</wheel_separation>
      <wheel_radius>0.105</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_acceleration>0.8</max_linear_acceleration>
      <min_linear_acceleration>-0.8</min_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
      <min_angular_acceleration>-3.0</min_angular_acceleration>
      <max_linear_velocity>0.6</max_linear_velocity>
      <min_linear_velocity>-0.6</min_linear_velocity>
      <max_angular_velocity>2.5</max_angular_velocity>
      <min_angular_velocity>-2.5</min_angular_velocity>
    </plugin>
  </gazebo>

</robot>
