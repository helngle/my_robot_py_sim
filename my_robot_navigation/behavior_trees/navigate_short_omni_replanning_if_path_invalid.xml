<!-- Short-range navigation keeps collision-aware Nav2 planning but bypasses
     RotationShim so the Omni MPPI controller may reverse or crab sideways. -->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="3" name="NavigateShortRecovery">
      <PipelineSequence>
        <RateController hz="1.0" name="RateControllerComputeShortPath">
          <RecoveryNode number_of_retries="1" name="RecoveryComputeShortPath">
            <Fallback name="FallbackComputeShortPath">
              <ReactiveSequence name="CheckIfNewShortPathNeeded">
                <Inverter>
                  <GlobalUpdatedGoal/>
                </Inverter>
                <IsPathValid path="{path}"/>
              </ReactiveSequence>
              <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            </Fallback>
            <ClearEntireCostmap name="ClearGlobalCostmap-Short" service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="RecoveryFollowShortPath">
          <FollowPath path="{path}" controller_id="ShortPath" goal_checker_id="ShortGoalChecker"/>
          <ClearEntireCostmap name="ClearLocalCostmap-Short" service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="FallbackShortRecoveries">
        <GoalUpdated/>
        <RoundRobin name="ShortRecoveryActions">
          <Sequence name="ShortClearingActions">
            <ClearEntireCostmap name="ClearLocalCostmap-ShortSubtree" service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-ShortSubtree" service_name="global_costmap/clear_entirely_global_costmap"/>
          </Sequence>
          <Wait name="WaitShortRecovery" wait_duration="2"/>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
